generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  WORKER
  BUSINESS
}

enum JobStatus {
  OPEN
  CLOSED
}

enum MatchStatus {
  ACCEPTED
  REJECTED
}

enum WorkStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
}

enum AttendanceMethod {
  QR
  MANUAL
}

enum PaymentStatus {
  PENDING
  PAID
}

enum FeeStatus {
  PENDING
  PAID
}

model User {
  id           String   @id @default(uuid())
  firstName    String
  lastName     String
  email        String   @unique
  phone        String?  @unique
  passwordHash String
  role         UserRole
  isVerified   Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  workerProfile   WorkerProfile?
  businessProfile BusinessProfile?

  postedJobs Job[]   @relation("BusinessJobs")
  matches    Match[] @relation("WorkerMatches")
}

model WorkerProfile {
  id                   String  @id @default(uuid())
  userId               String  @unique
  skills               String?
  experienceSummary    String?
  ratingAverage        Float   @default(0)
  completedShiftsCount Int     @default(0)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model BusinessProfile {
  id            String  @id @default(uuid())
  userId        String  @unique
  businessName  String
  industry      String?
  address       String?
  contactPerson String?
  ratingAverage Float   @default(0)
  isVerified    Boolean @default(false)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Job {
  id           String    @id @default(uuid())
  businessId   String
  title        String
  description  String?
  location     String
  date         DateTime
  startTime    DateTime
  endTime      DateTime
  payAmount    Float
  totalSlots   Int
  slotsFilled  Int       @default(0)
  minRating    Float?
  requirements Json?
  restrictions Json?
  status       JobStatus @default(OPEN)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  business User    @relation("BusinessJobs", fields: [businessId], references: [id], onDelete: Cascade)
  matches  Match[]
}

model Match {
  id                 String      @id @default(uuid())
  workerId           String
  jobId              String
  status             MatchStatus
  workStatus         WorkStatus  @default(PENDING)
  agreementTimestamp DateTime    @default(now())
  createdAt          DateTime    @default(now())

  worker User @relation("WorkerMatches", fields: [workerId], references: [id], onDelete: Cascade)
  job    Job  @relation(fields: [jobId], references: [id], onDelete: Cascade)

  attendance Attendance?
  payment    Payment?
  fee        Fee?

  @@unique([workerId, jobId])
}

model Attendance {
  id           String           @id @default(uuid())
  matchId      String           @unique
  checkInTime  DateTime?
  checkOutTime DateTime?
  method       AttendanceMethod
  isCompleted  Boolean          @default(false)
  createdAt    DateTime         @default(now())

  match Match @relation(fields: [matchId], references: [id], onDelete: Cascade)
}

model Payment {
  id            String        @id @default(uuid())
  matchId       String        @unique
  paymentStatus PaymentStatus @default(PENDING)
  updatedAt     DateTime      @updatedAt

  match Match @relation(fields: [matchId], references: [id], onDelete: Cascade)
}

model Fee {
  id        String    @id @default(uuid())
  matchId   String    @unique
  feeAmount Float
  feeStatus FeeStatus @default(PENDING)
  createdAt DateTime  @default(now())

  match Match @relation(fields: [matchId], references: [id], onDelete: Cascade)
}
